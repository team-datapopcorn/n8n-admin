# ─────────────────────────────────────────────
# n8n Admin 대시보드 환경변수
#
# 사용법:
#   cp .env.example .env.local
#   .env.local을 열어 실제 값을 입력하세요
# ─────────────────────────────────────────────

# 대시보드 타이틀 (선택)
APP_NAME="My n8n Admin"

# ── n8n 서버 설정 (필수) ─────────────────────
# n8n API 키: n8n 대시보드 → Settings → API → Create API Key
SERVER_NAME="My Server"
SERVER_URL=https://your-n8n-server.com
SERVER_API_KEY=your_api_key_here

# 서버가 여러 개라면 아래 블록을 복사해서 추가
# SERVER2_NAME="Backup Server"
# SERVER2_URL=https://your-second-n8n.com
# SERVER2_API_KEY=your_second_api_key

# ── 대시보드 인증 (필수) ─────────────────────
# 로그인 비밀번호
ADMIN_PASSWORD=change-me-please

# NextAuth 시크릿 — 터미널에서 생성:
#   openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# 로컬 개발: http://localhost:3000
# Vercel 배포: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ── AI 자동 정리 (선택) ──────────────────────
# Google Gemini API 키: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key

# Vercel Cron 인증 시크릿 (미설정 시 인증 없이 실행)
# CRON_SECRET=your-cron-secret

# ── GCP VM 관리 (선택) ───────────────────────
# GCP에 n8n을 설치한 경우에만 입력 (없으면 GCP 탭 자동 숨김)
# SERVER_HOSTING=gcp
# SERVER_GCP_PROJECT_ID=your-project-id
# SERVER_GCP_INSTANCE_NAME=your-instance-name
# SERVER_GCP_ZONE=asia-northeast3-a
