# ═══════════════════════════════════════════════════════════════════════
# n8n-admin 설정 파일
#
# 사용법:
#   cp .env.example .env
#   .env 파일을 열어 실제 값을 입력하세요.
#   .env 파일은 절대 Git에 커밋하지 마세요.
# ═══════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────
# 앱 기본 설정
# ───────────────────────────────────────────────────────────────────────
# 대시보드 타이틀, 브라우저 탭, 로그인 화면에 표시됩니다.
# 예) "My Company n8n", "팀 자동화 허브"
APP_NAME=My n8n Admin

# ───────────────────────────────────────────────────────────────────────
# n8n 서버 설정 (필수)
#
# n8n API 키 발급 방법:
#   1. n8n 대시보드 접속
#   2. Settings → API → Create API Key
#   3. 생성된 키를 아래에 입력
#
# 서버 URL은 슬래시(/) 없이 입력하세요.
# 예) https://n8n.example.com (O)   https://n8n.example.com/ (X)
# ───────────────────────────────────────────────────────────────────────
SERVER_NAME=My Server
SERVER_URL=https://your-n8n-server.com
SERVER_API_KEY=your_api_key_here

# ───────────────────────────────────────────────────────────────────────
# 서버 추가 (선택)
#
# 서버가 여러 개라면 아래 블록을 복사해서 추가하세요.
# 번호는 연속해야 합니다 (server2 없이 server3만 있으면 server3는 무시됩니다).
# ⚠️ scripts/_common.sh에도 해당 server3 case를 추가해야 합니다.
# ───────────────────────────────────────────────────────────────────────
# SERVER2_NAME=Backup Server
# SERVER2_URL=https://your-second-n8n.com
# SERVER2_API_KEY=your_second_api_key_here

# SERVER3_NAME=Dev Server
# SERVER3_URL=https://your-dev-n8n.com
# SERVER3_API_KEY=your_dev_api_key_here

# ───────────────────────────────────────────────────────────────────────
# GCP VM 관리 (선택)
#
# GCP VM에 n8n을 설치한 경우에만 입력하세요.
# 입력하지 않으면 Admin 대시보드의 GCP VM 탭이 자동으로 숨겨집니다.
# 설정 가이드: docs/gcp-setup.md
# ───────────────────────────────────────────────────────────────────────
# GCP_PROJECT_ID=your-project-id
# GCP_INSTANCE_NAME=your-instance-name
# GCP_ZONE=asia-northeast3-a   # 예) us-central1-a, asia-northeast3-a

# ───────────────────────────────────────────────────────────────────────
# Admin 대시보드 인증 (대시보드를 사용하는 경우 필수)
# ───────────────────────────────────────────────────────────────────────
# 대시보드 로그인 비밀번호
ADMIN_PASSWORD=change-me-please

# NextAuth 시크릿. 터미널에서 생성:
#   openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# 배포 URL
# - 로컬 개발: http://localhost:3000
# - Vercel 배포: https://your-admin.vercel.app
# ⚠️ Vercel 배포 후 반드시 실제 URL로 변경하세요.
#    NEXTAUTH_URL이 잘못되면 로그인이 작동하지 않습니다.
# 자세한 내용: docs/vercel-deploy.md
NEXTAUTH_URL=http://localhost:3000
